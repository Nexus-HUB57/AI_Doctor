class ClinicalDataLoader:
    @staticmethod
    def carregar_dados(fonte="tcga", **kwargs):
        if fonte == "tcga":
            conn = TCGAConnector()
            return conn.baixar_dados_clinicos(**kwargs)
        elif fonte == "mimic":
            conn = MIMICConnector()
            return conn.buscar_pacientes_oncologicos(**kwargs)
        else:
            # Fallback para sintético
            return gerar_dados_sinteticos_realistas(**kwargs)
