class VetorStore:
    def __init__(self, collection_name="casos_clinicos", embedder=None):
        self.embedder = embedder or ClinicalEmbedder()
        self.client = chromadb.PersistentClient(path="./chroma_db")
        self.collection = self.client.get_or_create_collection(name=collection_name)

    def adicionar_casos(self, df):
        ids = df['patient_id'].astype(str).tolist()
        # Gera embeddings usando o modelo clínico
        embeddings = [self.embedder.embed_patient(row.to_dict()) for _, row in df.iterrows()]
        metadados = df[['ECOG', 'outcome']].to_dict('records')
        self.collection.add(ids=ids, embeddings=embeddings, metadatas=metadados)
