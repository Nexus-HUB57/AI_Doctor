# 1. DATA LOADER – TCGA / MIMIC-III (SIMULADO)
# ================================================================
class ClinicalDataLoader:
    """
    Carrega dados de pacientes de arquivos CSV (formato TCGA-like).
    Para uso real, substituir por leitura de arquivos baixados do portal GDC.
    """
    @staticmethod
    def carregar_dados_tcga(caminho_csv):
        # Simula leitura de um CSV com colunas: patient_id, ctDNA, CTC, TMB, PD_L1, TILs, ECOG, outcome
        # Retorna um DataFrame
        df = pd.read_csv(caminho_csv) if caminho_csv else None
        return df

    @staticmethod
    def gerar_dados_sinteticos_realistas(n=5000):
        """Gera dados sintéticos com distribuições semelhantes às reais."""
        np.random.seed(42)
        data = {
            'patient_id': [f'P{i:04d}' for i in range(n)],
            'ctDNA': np.random.beta(2, 5, n),  # média ~0.3
            'CTC': np.random.lognormal(2, 1, n),  # assimetria positiva
            'TMB': np.random.gamma(2, 4, n),  # média ~8
            'PD_L1': np.random.beta(1.5, 3, n),  # média ~0.3
            'TILs': np.random.beta(1, 3, n),  # média ~0.25
            'ECOG': np.random.choice([0,1,2,3,4], n, p=[0.3,0.3,0.2,0.1,0.1]),
            'outcome': np.random.choice(['response', 'progression', 'stable'], n, p=[0.3,0.4,0.3])
        }
        return pd.DataFrame(data)

# ================================================================
# 2. BANCO VETORIAL (ChromaDB)
# ================================================================
class VetorStore:
    def __init__(self, collection_name="casos_clinicos", persist_dir="./chroma_db"):
        self.client = chromadb.PersistentClient(path=persist_dir)
        self.embedding_fn = embedding_functions.DefaultEmbeddingFunction()
        self.collection = self.client.get_or_create_collection(
            name=collection_name,
            embedding_function=self.embedding_fn
        )

    def adicionar_casos(self, df, vetor_cols):
        """Adiciona casos ao banco vetorial."""
        ids = df['patient_id'].astype(str).tolist()
        # Converte vetores para embeddings (aqui usamos os próprios vetores como embedding)
        # Em produção, usar um modelo de embedding treinado.
        embeddings = df[vetor_cols].values.tolist()
        metadados = df[['ECOG', 'outcome']].to_dict('records')
        self.collection.add(ids=ids, embeddings=embeddings, metadatas=metadados)

    def buscar_analogos(self, vetor_consulta, top_k=5):
        """Retorna os top_k casos mais similares."""
        resultados = self.collection.query(query_embeddings=[vetor_consulta], n_results=top_k)
        return resultados

