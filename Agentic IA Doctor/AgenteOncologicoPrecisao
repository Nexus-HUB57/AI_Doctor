    def _indexar_historico_chroma(self):
        """Preenche o ChromaDB com os casos históricos."""
        # Extrai vetores do DataFrame
        df = self.df_historico.copy()
        df['patient_id'] = [f"HIST_{i}" for i in range(len(df))]
        vetor_cols = ['ctDNA', 'CTC', 'TMB', 'PD_L1', 'TILs']  # assumindo que existem
        # Normaliza colunas se necessário
        for col in vetor_cols:
            if col not in df.columns:
                df[col] = np.random.rand(len(df))  # fallback
        self.vetor_store.adicionar_casos(df, vetor_cols)

    # ----------------------------------------------------------------
    # BUSCA NO CHROMADB (substitui a memória RAG)
    # ----------------------------------------------------------------
    def _recuperar_analogos_chroma(self, vetor_consulta, top_k=5):
        resultados = self.vetor_store.buscar_analogos(vetor_consulta.tolist(), top_k)
        # Converte para formato similar ao usado anteriormente
        analogos = []
        if resultados and 'metadatas' in resultados:
            for i, meta in enumerate(resultados['metadatas'][0]):
                analogos.append({
                    'desfecho': meta.get('outcome', 'stable'),
                    'vetor': None  # não usamos o vetor de volta
                })
        return analogos

    # ----------------------------------------------------------------
    # GERAR CENÁRIOS (COM CHROMA OU MEMÓRIA)
    # ----------------------------------------------------------------
    def _gerar_cenarios_prognosticos(self, row_atual):
        vetor_atual = self.assinatura.vetorizar()
        if self.usar_chroma:
            analogos = self._recuperar_analogos_chroma(vetor_atual, top_k=5)
            # Calcula probabilidades baseadas nos desfechos dos análogos
            if analogos:
                outcomes = [a['desfecho'] for a in analogos]
                prob_melhora_rag = sum(1 for o in outcomes if o == 'response') / len(outcomes)
                prob_piora_rag = sum(1 for o in outcomes if o == 'progression') / len(outcomes)
            else:
                prob_melhora_rag = 0.33
                prob_piora_rag = 0.33
        else:
            analogos = self.memoria.recuperar_analogos(vetor_atual, top_k=5)
            if analogos:
                prob_melhora_rag = sum(1 for a in analogos if a['desfecho'] > 0.015) / len(analogos)
                prob_piora_rag = sum(1 for a in analogos if a['desfecho'] < -0.015) / len(analogos)
            else:
                prob_melhora_rag = 0.33
                prob_piora_rag = 0.33

        # Simulação Monte Carlo (mantida)
        volatilidade = max(0.005, row_atual.get('desvio_ctDNA', 0.01) / (row_atual.get('ctDNA', 0.5) + 1e-9))
        cenarios = []
        for _ in range(150):
            valor_sim = row_atual.get('ctDNA', 0.5)
            dose_sim = self.dose_atual * random.uniform(0.8, 1.2)
            for _ in range(self.paradigma.janela_prognostica):
                eficacia = self.clonal.aplicar_pressao(dose_sim, self.paradigma.toxicidade_da_droga)
                viés = (prob_melhora_rag - prob_piora_rag) * 0.005 * (1 + (1 - eficacia) * 0.5)
                ruido = np.random.normal(0, volatilidade)
                if random.random() < 0.04:
                    ruido *= 2.5
                valor_sim *= (1 + viés + ruido)
                valor_sim = max(0.01, valor_sim)
            cenarios.append((valor_sim - row_atual.get('ctDNA', 0.5)) / (row_atual.get('ctDNA', 0.5) + 1e-9))

        ciclos_ate_resistencia = self.clonal.prever_resistencia_em(self.paradigma.janela_prognostica)

        return {
            'prob_melhora_rag': prob_melhora_rag,
            'prob_piora_rag': prob_piora_rag,
            'prob_sim_melhora': sum(1 for x in cenarios if x > 0.015) / len(cenarios),
            'prob_sim_piora': sum(1 for x in cenarios if x < -0.015) / len(cenarios),
            'ciclos_ate_resistencia': ciclos_ate_resistencia,
            'cenarios': cenarios
        }

