# 6. VALIDAÇÃO PROSPECTIVA (SIMULAÇÃO RETROSPECTIVA)
# ================================================================
class ValidadorProspectivo:
    def __init__(self, agente):
        self.agente = agente
        self.historico_acoes = []
        self.acordos = 0
        self.total = 0

    def simular_paciente(self, dados_paciente):
        """Simula o acompanhamento de um paciente real e compara com o comitê."""
        # Comitê fictício: regra simples baseada em ECOG e ctDNA
        ecog = dados_paciente.get('ECOG', 0)
        ctDNA = dados_paciente.get('ctDNA', 0.5)
        if ecog >= 3:
            decisao_comite = 'REDUZIR' if ctDNA > 0.3 else 'OBSERVAR'
        else:
            if ctDNA > 0.6:
                decisao_comite = 'INTENSIFICAR'
            elif ctDNA > 0.3:
                decisao_comite = 'MANTER_DOSE'
            else:
                decisao_comite = 'OBSERVAR'

        # Executa o agente para este paciente (simula um ciclo)
        self.agente.executar_ciclo(dados_paciente, ciclo_id=len(self.historico_acoes))
        acao_agente = self.agente._reagir(
            self.agente.matriz_probabilidade.get(self.agente.estado_atual, {}),
            self.agente._gerar_cenarios_prognosticos(dados_paciente),
            self.agente.emocoes
        )[0]

        # Compara
        concordancia = acao_agente == decisao_comite
        self.acordos += concordancia
        self.total += 1

        # Gera relatório
        relatorio = self.agente.explicador.gerar_relatorio(
            dados_paciente, acao_agente, 0.8, {}, {}
        )
        return {
            'paciente': dados_paciente,
            'acao_agente': acao_agente,
            'decisao_comite': decisao_comite,
            'concordancia': concordancia,
            'relatorio': relatorio
        }

    def relatorio_validacao(self):
        return {
            'total_pacientes': self.total,
            'concordancia_global': self.acordos / self.total if self.total > 0 else 0,
            'historico': self.historico_acoes
        }

