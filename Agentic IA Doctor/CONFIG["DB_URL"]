            fracao_resistentes=0.25,
            ecog=paciente["ecog_real"],
            acao=acao_agente
        )

        status = validador.avaliar_concordancia(acao_agente, paciente["decisao_comite_tumores"], paciente["ecog_real"])

        relatorio = ExplicadorSHAPClinico.formatar_relatorio_xai(
            acao=acao_agente,
            esquema_nccn=esquema_nccn,
            shap_values=shap_vals,
            ecog=paciente["ecog_real"],
            mutacao_chave="KRAS G12D"
        )

        print(f"\n👤 PACIENTE: {paciente['id']}")
        print(f"   Status: {status}")
        print(relatorio)

        auditor.registrar_evento(
            patient_id=paciente['id'],
            acao=acao_agente,
            dose=agente.dose_atual,
            linha=agente.linha_terapeutica,
            ecog=paciente['ecog_real'],
            eficacia=agente.clonal.eficacia_relativa(),
            estado=agente.estado_atual,
            relatorio_xai=relatorio,
            shap_contrib=shap_vals
        )

    # 6. Relatório final
    print(validador.relatorio_desempenho_prospectivo())

    # 7. Iniciar scheduler (se disponível)
    if BackgroundScheduler:
        scheduler = iniciar_scheduler()
        print("📅 Scheduler de aprendizado contínuo iniciado.")
    else:
        print("Scheduler não iniciado (APScheduler ausente).")

    print("=" * 80)
    print("✅ Pipeline concluído com sucesso.")

if __name__ == "__main__":
    main()
