def job_aprendizado_continuo():
    print(f"[{datetime.datetime.now()}] Executando rotina de aprendizado contínuo...")
    try:
        df_novos = pd.read_csv("novos_casos.csv")
        if not df_novos.empty:
            embedder = ClinicalEmbedder()
            chroma = VetorStoreRAG(embedder=embedder)
            chroma.adicionar_casos(df_novos)

            model = DecisionModel()
            df_hist = pd.read_csv("historico_completo.csv")
            def alvo(row):
                if row['ctDNA'] > 0.6 and row['ECOG'] < 3:
                    return 2
                elif row['ctDNA'] < 0.3 or row['ECOG'] >= 3:
                    return 0
                else:
                    return 1
            df_hist['target'] = df_hist.apply(alvo, axis=1)
            model.treinar(df_hist)
            model.salvar()
            atualizar_explicador_shap(model, df_hist)
            print("🔬 [OK] Modelo e Explainer SHAP sincronizados com sucesso.")
    except Exception as e:
        print(f"❌ Erro no ciclo de re-treinamento: {e}")

def iniciar_scheduler():
    if BackgroundScheduler is None:
        print("APScheduler não instalado. pip install apscheduler")
        return None
    scheduler = BackgroundScheduler()
    scheduler.add_job(job_aprendizado_continuo, 'interval', hours=CONFIG["SCHEDULE_INTERVAL_HOURS"])
    scheduler.start()
    return scheduler


