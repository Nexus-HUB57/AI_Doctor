class VetorStoreRAG:
    def __init__(self, embedder=None):
        self.embedder = embedder or ClinicalEmbedder()
        if chromadb is not None:
            self.client = chromadb.PersistentClient(path="./chroma_db")
            self.collection = self.client.get_or_create_collection(name="casos_clinicos_oncologia")
