def main():
    print("=" * 80)
    print("AI Doctor Engine - Modo Produção (Com Pooling PostgreSQL + SHAP Dinâmico)")
    print("=" * 80)

    # 1. Carregar dados históricos (simulados)
    np.random.seed(42)
    n = 500
    df = pd.DataFrame({
        'patient_id': [f'P{i:04d}' for i in range(n)],
        'ctDNA': np.random.beta(2, 5, n),
        'CTC': np.random.lognormal(1.2, 0.5, n),
        'TMB': np.random.gamma(2, 4, n),
        'PD_L1': np.random.beta(1.5, 3, n),
        'TILs': np.random.beta(1, 3, n),
        'ECOG': np.random.choice([0, 1, 2, 3], n, p=[0.4, 0.3, 0.2, 0.1])
    })
    def alvo(row):
        if row['ctDNA'] > 0.6 and row['ECOG'] < 3:
            return 2
        elif row['ctDNA'] < 0.3 or row['ECOG'] >= 3:
            return 0
        else:
            return 1
    df['target'] = df.apply(alvo, axis=1)

    # 2. Indexar no ChromaDB (opcional)
    print("[1] Indexando ChromaDB...")
    chroma = BancoVetorialChromaDB()
    for i, row in df.head(100).iterrows():
        vetor = np.array([row['ctDNA'], np.log1p(row['CTC'])/10.0, row['TMB']/50.0, row['PD_L1'], row['TILs'], row['ECOG']/4.0])
        chroma.indexar_caso_clinico(
            caso_id=row['patient_id'],
            vetor_caracteristicas=vetor,
            metadados={"ECOG": int(row['ECOG']), "ctDNA": float(row['ctDNA'])}
        )
    print(f"   ✅ {chroma.collection.count()} vetores indexados.")

    # 3. Treinar modelo e gerar SHAP
    print("[2] Treinando modelo de decisão...")
    model = DecisionModel()
