from sklearn.tree import DecisionTreeClassifier

class DecisionModel:
    def __init__(self):
        self.model = None
        self.feature_names = ['ctDNA', 'CTC', 'TMB', 'PD_L1', 'TILs', 'ECOG']

    def treinar(self, df: pd.DataFrame):
        X = df[self.feature_names]
        y = df['target']
        self.model = DecisionTreeClassifier(max_depth=5, random_state=42)
        self.model.fit(X, y)

    def salvar(self, path: str = CONFIG["MODEL_PATH"]):
        os.makedirs(os.path.dirname(path), exist_ok=True)
        with open(path, 'wb') as f:
            pickle.dump(self.model, f)

    def carregar(self, path: str = CONFIG["MODEL_PATH"]):
        with open(path, 'rb') as f:
            self.model = pickle.load(f)

    def prever(self, X: pd.DataFrame) -> np.ndarray:
        return self.model.predict(X[self.feature_names])


