# 10. SCHEDULER PARA APRENDIZADO CONTÍNUO
# ================================================================
def job_aprendizado_continuo():
    print(f"[{datetime.datetime.now()}] Executando aprendizado contínuo...")
    # Carrega dados novos (ex: de um banco de dados)
    # Aqui você implementaria a lógica para buscar novos casos com desfechos conhecidos,
    # re-treinar o modelo e reindexar o ChromaDB.
    # Exemplo simplificado:
    try:
        df_novos = pd.read_csv("novos_casos.csv")  # arquivo de exemplo
        if not df_novos.empty:
            # Treina modelo com dados históricos + novos
            # Atualiza ChromaDB
            embedder = ClinicalEmbedder()
            chroma = VetorStoreRAG(embedder=embedder)
            chroma.adicionar_casos(df_novos)
            # Re-treina modelo
            model = DecisionModel()
            # Supondo que temos um histórico completo
            df_hist = pd.read_csv("historico_completo.csv")
            model.treinar(df_hist)
            model.salvar()
            print("Aprendizado contínuo concluído.")
    except Exception as e:
        print(f"Erro no job de aprendizado: {e}")

def iniciar_scheduler():
    if BackgroundScheduler is None:
        print("APScheduler não instalado. pip install apscheduler")
        return
    scheduler = BackgroundScheduler()
    scheduler.add_job(job_aprendizado_continuo, 'interval', hours=CONFIG["SCHEDULE_INTERVAL_HOURS"])
    scheduler.start()
    return scheduler


# ================================================================
# 11. FUNÇÃO PRINCIPAL (EXECUÇÃO)
# ================================================================
def main():
    print("="*80)
    print("AI Doctor Engine - Modo Produção")
    print("="*80)

    # 1. Conectar ao TCGA e baixar dados
    print("\n[1] Carregando dados do TCGA (ou fallback)...")
    conn = TCGAConnectorReal()
    df = conn.baixar_dados_clinicos(cancer_type=CONFIG["TCGA"]["cancer_type"], limit=CONFIG["TCGA"]["limit"])
    print(f"   Obtidos {len(df)} pacientes.")

    # 2. Indexar no ChromaDB com ClinicalBERT
    print("\n[2] Indexando no ChromaDB com ClinicalBERT...")
    embedder = ClinicalEmbedder()
    chroma = VetorStoreRAG(embedder=embedder, persist_dir=CONFIG["CHROMA_DB_PATH"])
    chroma.adicionar_casos(df)
    print(f"   Indexados {chroma.collection.count()} casos.")

    # 3. Treinar modelo de decisão e gerar explicador SHAP
    print("\n[3] Treinando modelo de decisão e gerando SHAP...")
    model = DecisionModel()
    # Precisamos de um histórico para treinar; usamos os dados baixados
    # e geramos um alvo simulado (para demonstração)
    df_temp = df.copy()
    # Criar alvo: 0=reduzir, 1=manter, 2=intensificar
    def alvo(row):
        if row['ctDNA'] > 0.6 and row['ECOG'] < 3:
            return 2
        elif row['ctDNA'] < 0.3 or row['ECOG'] >= 3:
            return 0
        else:
            return 1
    df_temp['target'] = df_temp.apply(alvo, axis=1)
    model.treinar(df_temp)
    model.salvar(CONFIG["MODEL_PATH"])
    print("   Modelo salvo.")

    # Gerar explainer SHAP
    if shap is not None:
        X_background = df_temp[model.feature_names].sample(100, random_state=42)
        explainer = shap.TreeExplainer(model.model, X_background)
        import pickle
        os.makedirs(os.path.dirname(CONFIG["SHAP_EXPLAINER_PATH"]), exist_ok=True)
        with open(CONFIG["SHAP_EXPLAINER_PATH"], 'wb') as f:
            pickle.dump(explainer, f)
        print("   Explicador SHAP salvo.")

    # 4. Configurar auditoria (PostgreSQL ou SQLite)
    print("\n[4] Configurando auditoria...")
    auditor = AuditorClinico(db_url=CONFIG["DB_URL"])
    # Insere um registro de teste
    auditor.registrar_evento(
        patient_id="TESTE",
        acao="INICIALIZACAO",
        dose=0.0,
        linha=0,
        ecog=0,
        eficacia=1.0,
        estado="SISTEMA_INICIADO",
        relatorio_xai="Sistema inicializado com sucesso.",
        shap_contrib={}
    )
    print("   Auditoria configurada.")

    # 5. Iniciar scheduler para aprendizado contínuo
    print("\n[5] Iniciando scheduler de aprendizado contínuo...")
    scheduler = iniciar_scheduler()
    if scheduler:
        print(f"   Scheduler ativo (intervalo de {CONFIG['SCHEDULE_INTERVAL_HOURS']} horas).")
    else:
        print("   Scheduler não iniciado.")

    # 6. Dashboard (opcional)
    print("\n[6] Para iniciar o dashboard, execute: streamlit run main.py -- --dashboard")
    if "--dashboard" in sys.argv:
        run_dashboard()
    else:
        print("   Dashboard disponível via 'streamlit run main.py -- --dashboard'.")

    print("\n🏥 Sistema pronto. Pressione Ctrl+C para interromper.")
    try:
        # Mantém o script rodando para o scheduler
        import time
        while True:
            time.sleep(1)
    except KeyboardInterrupt:
        print("\nEncerrando...")
        if scheduler:
            scheduler.shutdown()
        sys.exit(0)

if __name__ == "__main__":
    main()
