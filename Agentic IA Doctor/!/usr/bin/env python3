# ================================================================
# 2. CONECTOR TCGA REAL (com fallback)
# ================================================================
class TCGAConnectorReal:
    """
    Conecta ao TCGA via TCGAbiolinks (requer R e pacote TCGAbiolinks)
    """
    def __init__(self):
        self.tcga_available = False
        try:
            # Tenta importar o módulo R via rpy2 ou subprocess? 
            # Na prática, TCGAbiolinks é um pacote R. Para Python, podemos usar a API REST do GDC.
            # Vamos usar requests para consultar a API pública do GDC.
            import requests
            self.requests = requests
            self.tcga_available = True
        except ImportError:
            self.tcga_available = False

    def baixar_dados_clinicos(self, cancer_type="LUAD", limit=1000):
        if not self.tcga_available:
            print("⚠️ API GDC não disponível. Usando dados sintéticos.")
            return self._gerar_coorte_sintetica(limit)

        # Usa a API GDC para obter dados clínicos e moleculares
        # Endpoint para casos de câncer de pulmão (LUAD)
        url = f"https://api.gdc.cancer.gov/cases?filters={{\"op\":\"and\",\"content\":[{{\"op\":\"in\",\"content\":{{\"field\":\"projects.project_id\",\"value\":[\"TCGA-{cancer_type}\"]}}}}]}}&fields=case_id,demographic,diagnoses,exposures,family_histories,maintenance,project,summary,clinical_supplement&size={limit}"
        try:
            response = self.requests.get(url)
            response.raise_for_status()
            data = response.json()
            casos = data.get('data', {}).get('hits', [])
            return self._extrair_biomarcadores(casos)
        except Exception as e:
            print(f"Erro ao acessar GDC API: {e}. Usando fallback sintético.")
            return self._gerar_coorte_sintetica(limit)

    def _extrair_biomarcadores(self, casos):
        records = []
        for case in casos:
            # Extrai dados demográficos e diagnósticos
            demog = case.get('demographic', {})
            age = demog.get('age_at_diagnosis', 60)
            gender = demog.get('gender', 'male')
            # Diagnóstico
            diag = case.get('diagnoses', [{}])[0]
            stage = diag.get('stage', 'I')
            # Simulação de biomarcadores baseados em estágio e idade (apenas para demo)
            # Em produção, você obteria dados moleculares reais via endpoint de expressão/mutação
            ctDNA = 0.1 + 0.15 * (int(stage[-1]) if stage[-1].isdigit() else 1) + np.random.normal(0, 0.05)
            ctDNA = np.clip(ctDNA, 0.01, 1.0)
            records.append({
                'patient_id': case['case_id'],
                'ctDNA': float(ctDNA),
                'CTC': float(np.random.lognormal(1, 0.5)),
                'TMB': float(np.random.gamma(2, 4)),
                'PD_L1': float(np.random.beta(1.5, 3)),
                'TILs': float(np.random.beta(1, 3)),
                'ECOG': int(np.random.choice([0,1,2,3], p=[0.4,0.3,0.2,0.1])),
                'outcome': 'response' if ctDNA < 0.4 else 'progression'
            })
        return pd.DataFrame(records)

    def _gerar_coorte_sintetica(self, limit):
        return TCGAConnectorReal._gerar_sintetico(limit)

    @staticmethod
    def _gerar_sintetico(limit):
        np.random.seed(42)
        records = []
        for i in range(limit):
            ctDNA = float(np.random.uniform(0.05, 0.85))
            records.append({
                'patient_id': f"SYNTH-P{i:04d}",
                'ctDNA': ctDNA,
                'CTC': float(np.random.lognormal(1.2, 0.4)),
                'TMB': float(np.random.gamma(2.5, 4.5)),
                'PD_L1': float(np.random.beta(1.8, 3.2)),
                'TILs': float(np.random.beta(1.2, 2.8)),
                'ECOG': int(np.random.choice([0,1,2,3], p=[0.5,0.3,0.15,0.05])),
                'outcome': 'response' if ctDNA < 0.4 else 'progression'
            })
        return pd.DataFrame(records)


# ================================================================
# 3. EMBEDDING COM CLINICALBERT
# ================================================================
class ClinicalEmbedder:
    def __init__(self, model_name="emilyalsentzer/Bio_ClinicalBERT"):
        if AutoTokenizer is None or AutoModel is None:
            raise RuntimeError("transformers não instalado. pip install transformers")
        self.tokenizer = AutoTokenizer.from_pretrained(model_name)
        self.model = AutoModel.from_pretrained(model_name)
        self.model.eval()

    def embed_text(self, text: str) -> np.ndarray:
        import torch
        inputs = self.tokenizer(text, return_tensors="pt", truncation=True, max_length=512)
        with torch.no_grad():
            outputs = self.model(**inputs)
        embedding = outputs.last_hidden_state.mean(dim=1).squeeze().numpy()
        return embedding

    def embed_patient(self, patient_data: dict) -> np.ndarray:
        texto = (
            f"Paciente oncológico ECOG {patient_data.get('ECOG', 0)}. "
            f"ctDNA {patient_data.get('ctDNA', 0.5):.2f}, CTC {patient_data.get('CTC', 10):.1f}/mL, "
            f"TMB {patient_data.get('TMB', 8):.1f} mut/Mb, PD-L1 {patient_data.get('PD_L1', 0.2):.2f}, "
            f"TILs {patient_data.get('TILs', 0.1):.2f}. Desfecho {patient_data.get('outcome', 'unknown')}."
        )
        return self.embed_text(texto)


# ================================================================
# 4. BANCO VETORIAL CHROMADB
# ================================================================
class VetorStoreRAG:
    def __init__(self, collection_name="casos_clinicos", embedder=None, persist_dir="./chroma_db"):
        if chromadb is None:
            raise RuntimeError("chromadb não instalado. pip install chromadb")
        self.embedder = embedder or ClinicalEmbedder()
        self.client = chromadb.PersistentClient(path=persist_dir)
        self.collection = self.client.get_or_create_collection(name=collection_name)

    def adicionar_casos(self, df: pd.DataFrame):
        ids = df['patient_id'].astype(str).tolist()
        embeddings = [self.embedder.embed_patient(row.to_dict()).tolist() for _, row in df.iterrows()]
        metadados = df[['ECOG', 'outcome', 'ctDNA', 'TMB']].to_dict('records')
        self.collection.add(ids=ids, embeddings=embeddings, metadatas=metadados)

    def buscar_analogos(self, vetor_consulta: np.ndarray, top_k=5):
        if self.collection.count() == 0:
            return []
        resultados = self.collection.query(query_embeddings=[vetor_consulta.tolist()], n_results=top_k)
        casos = []
        if resultados and 'metadatas' in resultados:
            for meta in resultados['metadatas'][0]:
                casos.append(meta)
        return casos


# ================================================================
# 5. MODELO DE DECISÃO (para SHAP real)
# ================================================================
class DecisionModel:
    def __init__(self):
        self.model = None
        self.feature_names = ['ctDNA', 'CTC', 'TMB', 'PD_L1', 'TILs', 'ECOG']

    def treinar(self, df: pd.DataFrame):
        """
        Treina um modelo simples (RandomForest) para prever a ação recomendada.
        Ação: 0=Reduzir, 1=Manter, 2=Intensificar
        """
        from sklearn.ensemble import RandomForestClassifier
        X = df[self.feature_names].fillna(0)
        # Gera um alvo simulado: baseado em ctDNA e ECOG
        def regra(linha):
            ct = linha['ctDNA']
            ecog = linha['ECOG']
            if ct > 0.6 and ecog < 3:
                return 2  # intensificar
            elif ct < 0.3 or ecog >= 3:
                return 0  # reduzir
            else:
                return 1  # manter
        y = df.apply(regra, axis=1)
        self.model = RandomForestClassifier(n_estimators=100, random_state=42)
        self.model.fit(X, y)
        return self.model

    def prever_probas(self, X):
        if self.model is None:
            raise ValueError("Modelo não treinado.")
        return self.model.predict_proba(X)

    def salvar(self, path=CONFIG["MODEL_PATH"]):
        import pickle
        os.makedirs(os.path.dirname(path), exist_ok=True)
        with open(path, 'wb') as f:
            pickle.dump(self.model, f)

    def carregar(self, path=CONFIG["MODEL_PATH"]):
        import pickle
        with open(path, 'rb') as f:
            self.model = pickle.load(f)


# ================================================================
# 6. SHAP REAL
# ================================================================
class ExplicadorSHAPReal:
    def __init__(self, model, feature_names, X_background):
        if shap is None:
            raise RuntimeError("shap não instalado. pip install shap")
        self.explainer = shap.TreeExplainer(model, X_background)
        self.feature_names = feature_names

    def explicar(self, X_instance):
        shap_values = self.explainer.shap_values(X_instance)
        # Para problema multiclasse, pegamos a classe de maior probabilidade
        # Simplificando: retorna os valores da classe 2 (intensificar) como exemplo
        if isinstance(shap_values, list):
            # Multi-classe
            shap_class = shap_values[2]  # classe 'intensificar'
        else:
            shap_class = shap_values
        return shap_class

    def gerar_relatorio(self, X_instance, decisao):
        shap_vals = self.explicar(X_instance)
        # Formatar como dicionário de contribuições
        contrib = {}
        for i, name in enumerate(self.feature_names):
            contrib[name] = float(shap_vals[0][i])  # assumindo shap_vals é array 2D
        # Relatório textual
        top_driver = max(contrib.items(), key=lambda x: abs(x[1]))
        relatorio = (
            f"SHAP: decisão {decisao}. "
            f"Principal driver: {top_driver[0]} ({top_driver[1]:+.3f}). "
            f"Contribuições: " + ", ".join([f"{k}={v:+.3f}" for k,v in contrib.items()])
        )
        return relatorio, contrib


