# 7. AUDITORIA COM POSTGRESQL
# ================================================================
if create_engine is not None:
    Base = declarative_base()

    class DecisaoClinicaAudit(Base):
        __tablename__ = 'decisoes_auditoria_medica'
        id = Column(Integer, primary_key=True)
        patient_id = Column(String(50), index=True)
        timestamp = Column(DateTime, default=datetime.datetime.utcnow)
        conduta_acao = Column(String(50))
        dosagem_mg = Column(Float)
        linha_terapeutica = Column(Integer)
        ecog_ps = Column(Integer)
        eficacia_clonal = Column(Float)
        estado_patologico = Column(String(150))
        relatorio_xai = Column(String(3000))
        shap_contrib = Column(JSON)  # guarda contribuições SHAP

    class AuditorClinico:
        def __init__(self, db_url=CONFIG["DB_URL"]):
            self.engine = create_engine(db_url)
            Base.metadata.create_all(self.engine)
            self.Session = sessionmaker(bind=self.engine)

        def registrar_evento(self, patient_id, acao, dose, linha, ecog, eficacia, estado, relatorio_xai, shap_contrib):
            session = self.Session()
            try:
                reg = DecisaoClinicaAudit(
                    patient_id=patient_id,
                    conduta_acao=acao,
                    dosagem_mg=float(dose),
                    linha_terapeutica=int(linha),
                    ecog_ps=int(ecog),
                    eficacia_clonal=float(eficacia),
                    estado_patologico=str(estado),
                    relatorio_xai=relatorio_xai,
                    shap_contrib=shap_contrib
                )
                session.add(reg)
                session.commit()
            except Exception as e:
                session.rollback()
                raise e
            finally:
                session.close()
else:
    # Fallback: auditoria em SQLite
    from sqlalchemy import create_engine
    Base = declarative_base()
    class DecisaoClinicaAudit(Base):
        __tablename__ = 'decisoes'
        id = Column(Integer, primary_key=True)
        patient_id = Column(String(50))
        timestamp = Column(DateTime, default=datetime.datetime.utcnow)
        conduta_acao = Column(String(50))
        dosagem_mg = Column(Float)
        linha_terapeutica = Column(Integer)
        ecog_ps = Column(Integer)
        eficacia_clonal = Column(Float)
        estado_patologico = Column(String(150))
        relatorio_xai = Column(String(3000))
        shap_contrib = Column(JSON)
    class AuditorClinico:
        def __init__(self, db_url="sqlite:///audit.db"):
            self.engine = create_engine(db_url)
            Base.metadata.create_all(self.engine)
            self.Session = sessionmaker(bind=self.engine)
        def registrar_evento(self, patient_id, acao, dose, linha, ecog, eficacia, estado, relatorio_xai, shap_contrib):
            session = self.Session()
            try:
                reg = DecisaoClinicaAudit(
                    patient_id=patient_id,
                    conduta_acao=acao,
                    dosagem_mg=float(dose),
                    linha_terapeutica=int(linha),
                    ecog_ps=int(ecog),
                    eficacia_clonal=float(eficacia),
                    estado_patologico=str(estado),
                    relatorio_xai=relatorio_xai,
                    shap_contrib=shap_contrib
                )
                session.add(reg)
                session.commit()
            except Exception as e:
                session.rollback()
                raise e
            finally:
                session.close()

# ================================================================
# 8. AGENTE ONCOLÓGICO (CORE)
# ================================================================
class AgenteOncologicoPrecisao:
    def __init__(self, df_historico, modelo_decisao=None):
        self.df_historico = df_historico.copy()
        self.modelo = modelo_decisao
        self.dose_atual = 0.0
        self.linha_terapeutica = 0
        self.estado_atual = "INICIAL"
        self.fisiologia = type('Fisiologia', (), {'ecog': 0})()
        self.clonal = type('Clonal', (), {'fracao_resistentes': 0.1, 'historico_eficacia': [0.9]})()
        self.clonal.eficacia_relativa = lambda: self.clonal.historico_eficacia[-1]
        self.paradigma = type('Paradigma', (), {'modo_terapia': 'ERADICAR'})()

    def executar_ciclo(self, paciente_data: dict):
        # Atualiza ECOG
        self.fisiologia.ecog = paciente_data.get('ECOG', 0)
        # Extrai features
        features = np.array([[
            paciente_data.get('ctDNA', 0.5),
            paciente_data.get('CTC', 10),
            paciente_data.get('TMB', 8),
            paciente_data.get('PD_L1', 0.2),
            paciente_data.get('TILs', 0.1),
            self.fisiologia.ecog
        ]])
        # Predição se modelo disponível
        if self.modelo is not None and hasattr(self.modelo, 'predict'):
            probas = self.modelo.predict_proba(features)
            # Decisão: 0=reduzir, 1=manter, 2=intensificar
            acao_idx = np.argmax(probas[0])
            if acao_idx == 0:
                acao = 'REDUZIR'
                self.dose_atual = max(0, self.dose_atual - 0.1)
            elif acao_idx == 1:
                acao = 'MANTER_DOSE'
            else:
                acao = 'INTENSIFICAR'
                self.dose_atual = min(1.0, self.dose_atual + 0.1)
        else:
            # Lógica simples
            ct = paciente_data.get('ctDNA', 0.5)
            if ct > 0.6 and self.fisiologia.ecog < 3:
                acao = 'INTENSIFICAR'
                self.dose_atual = min(1.0, self.dose_atual + 0.1)
            elif ct < 0.3 or self.fisiologia.ecog >= 3:
                acao = 'REDUZIR'
                self.dose_atual = max(0, self.dose_atual - 0.1)
            else:
                acao = 'MANTER_DOSE'
        self.estado_atual = f"ctDNA={paciente_data.get('ctDNA',0):.2f}|ECOG={self.fisiologia.ecog}"
        return acao

# ================================================================
# 9. DASHBOARD STREAMLIT
# ================================================================
def run_dashboard():
    if st is None:
        print("Streamlit não instalado. pip install streamlit")
        return
    st.set_page_config(layout="wide")
    st.title("🧬 AI Doctor - Painel de Oncologia de Precisão")

    # Inicializa o agente na sessão
    if 'agente' not in st.session_state:
        # Carrega dados e modelo
        df_hist = pd.DataFrame()  # será carregado do banco
        # Tenta carregar modelo treinado
        modelo = None
        if os.path.exists(CONFIG["MODEL_PATH"]):
            import pickle
            with open(CONFIG["MODEL_PATH"], 'rb') as f:
                modelo = pickle.load(f)
        st.session_state.agente = AgenteOncologicoPrecisao(df_hist, modelo)
        st.session_state.historico_ctdna = []
        st.session_state.acoes = []

    # Sidebar
    st.sidebar.header("Controle")
    modo = st.sidebar.selectbox("Estratégia", ["ERADICAR", "CONTER"])
    st.session_state.agente.paradigma.modo_terapia = modo

    # Upload de dados
    uploaded = st.file_uploader("Carregar novo exame (CSV)", type="csv")
    if uploaded:
        df_novo = pd.read_csv(uploaded)
        novo_paciente = df_novo.iloc[0].to_dict()
        # Executa ciclo
        acao = st.session_state.agente.executar_ciclo(novo_paciente)
        st.session_state.historico_ctdna.append(novo_paciente.get('ctDNA', 0.5))
        st.session_state.acoes.append(acao)

        # Exibe evolução
        df_plot = pd.DataFrame({
            "Ciclo": range(len(st.session_state.historico_ctdna)),
            "ctDNA": st.session_state.historico_ctdna
        })
        st.line_chart(df_plot.set_index('Ciclo'))

        # Métricas
        col1, col2, col3 = st.columns(3)
        col1.metric("Dose atual", f"{st.session_state.agente.dose_atual:.2f}")
        col2.metric("ECOG", st.session_state.agente.fisiologia.ecog)
        col3.metric("Última ação", acao)

        # Explicação SHAP (se modelo carregado)
        if st.button("Gerar relatório SHAP"):
            if os.path.exists(CONFIG["SHAP_EXPLAINER_PATH"]):
                import pickle
                with open(CONFIG["SHAP_EXPLAINER_PATH"], 'rb') as f:
                    explainer = pickle.load(f)
                features = np.array([[
                    novo_paciente.get('ctDNA', 0.5),
                    novo_paciente.get('CTC', 10),
                    novo_paciente.get('TMB', 8),
                    novo_paciente.get('PD_L1', 0.2),
                    novo_paciente.get('TILs', 0.1),
                    novo_paciente.get('ECOG', 0)
                ]])
                shap_vals = explainer.shap_values(features)
                st.write("Valores SHAP (classe intensificar):", shap_vals[0][2] if isinstance(shap_vals, list) else shap_vals)
            else:
                st.warning("Explainer SHAP não encontrado. Treine o modelo primeiro.")

    # Exibir auditoria
    if st.checkbox("Mostrar histórico de auditoria"):
        try:
            import pandas as pd
            from sqlalchemy import create_engine
            engine = create_engine(CONFIG["DB_URL"])
            df_audit = pd.read_sql("SELECT * FROM decisoes_auditoria_medica ORDER BY timestamp DESC LIMIT 20", engine)
            st.dataframe(df_audit)
        except Exception as e:
            st.error(f"Erro ao carregar auditoria: {e}")


