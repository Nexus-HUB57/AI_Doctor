# === DIMHEX — Digital Medical Health Explorer ===
DIMHEX_INTERVAL_MINUTES=240
DIMHEX_LOOKBACK_DAYS=30
DIMHEX_MAX_RESULTS_PER_SOURCE=50
DIMHEX_MIN_SCORE=0.25
DIMHEX_REQUEST_TIMEOUT=30
DIMHEX_PESQUISA_ATIVA=true
DIMHEX_ACTIVE_SOURCES=["pubmed","clinical_trials"]
