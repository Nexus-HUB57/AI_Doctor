# === GEMINI LLM (opcional — sistema funciona sem) ===
GEMINI_API_KEY=AIzaSyDummyNativeToken0000000000000000000000

# === SEGURANÇA ===
JWT_SECRET=d1mh3x_n4t1v3_s3cr3t_k3y_f0r_l0c4l_d3v
