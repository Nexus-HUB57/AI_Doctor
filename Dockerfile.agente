# ============================================================
# AI Doctor — Python Agente Oncologico + DIMHEX Engine
# ============================================================
FROM python:3.12-slim

WORKDIR /app

# System deps (gcc needed for some Python packages)
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user for security
RUN groupadd -r agente && useradd -r -g agente -d /app -s /sbin/nologin agente

# Copy requirements and install
COPY AI_Doctor/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy agent code
COPY AI_Doctor/ ./

# Data directory (mounted as volume)
RUN mkdir -p /data && chown -R agente:agente /app /data

# Environment defaults
ENV PYTHONUNBUFFERED=1
ENV CHROMA_DB_PATH=/data/chroma_db

# Drop to non-root user
USER agente

# Health check (Docker native)
HEALTHCHECK --interval=60s --timeout=10s --start-period=30s --retries=3 \
  CMD python -c "import chromadb; c=chromadb.PersistentClient(path='./chroma_db'); print('ok') if c.heartbeat() else exit(1)" || exit 1

# Run the agent daemon (DIMHEX + Scheduler)
CMD ["python", "main.py"]