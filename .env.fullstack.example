# ============================================================
# AI_Doctor v3.0 — Full-Stack Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit your .env file to version control.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual values
#   docker compose -f docker-compose.fullstack.yml up -d --build
# ============================================================

# --- Required: Google Gemini API ---
GEMINI_API_KEY=

# --- Required: Authentication ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# --- Required: Database ---
DB_ROOT_PASSWORD=
DB_USER=ai_doctor
DB_PASSWORD=
DB_NAME=ai_doctor

# --- Application ---
NODE_ENV=production
PORT=3000

# --- Optional: AWS S3 (file storage) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=ai-doctor-files

# --- Optional: Scientific APIs (DIMHEX research) ---
# PUBMED_API_KEY=
# SERPAPI_KEY=
# CLINICALTRIALS_API_KEY=

# --- Optional: DIMHEX Configuration ---
# DIMHEX_INTERVAL_MINUTES=240
# DIMHEX_LOOKBACK_DAYS=30
# DIMHEX_MAX_RESULTS_PER_SOURCE=50
# DIMHEX_MIN_SCORE=0.25