# ============================================================
# AI_Doctor v3.0 — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit your .env file to version control.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual values
# ============================================================

# --- Required ---
# Google Gemini API key for AI-powered oncology analysis.
# Obtain at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Authentication ---
# Secret key for JWT token signing.
# REQUIRED in production. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# --- Database ---
# PostgreSQL/MySQL connection string for persistent storage.
# When empty, the app uses an in-memory fallback store.
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# --- Application ---
# Node environment: "development" | "production" | "test"
NODE_ENV=development

# Server port (default: 3000)
PORT=3000

# --- Development Only ---
# Set to "true" to disable Vite HMR (used by AI Studio agent editing)
DISABLE_HMR=false

# --- Optional: CORS Origins ---
# Comma-separated list of allowed origins (default: http://localhost:3000)
# CORS_ORIGINS=http://localhost:3000,https://ai-doctor.example.com

# --- Optional: AWS S3 ---
# For storing reports, genomic sequences, and files.
# AWS_S3_BUCKET=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Optional: Agentic Python Engine Bridge ---
# URL of the FastAPI service exposing the Python organ (agente bayesiano, ChromaDB, SHAP).
# Leave empty to disable the bridge (TS stack will operate standalone with in-memory fallbacks).
# AGENTIC_API_URL=http://127.0.0.1:8000
# AGENTIC_TIMEOUT_MS=8000
# AGENTIC_CORS_ORIGINS=*